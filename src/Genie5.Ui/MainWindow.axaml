<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Genie5.Ui.MainWindow"
        Width="900"
        Height="700"
        Title="Genie5">

  <DockPanel>

    <!-- Top: Connection controls -->
    <StackPanel Orientation="Horizontal"
                DockPanel.Dock="Top"
                Margin="5"
                Spacing="5">

      <TextBox Name="HostBox"
               Width="200"
               Watermark="Host"
               Text="aardmud.org"/>

      <TextBox Name="PortBox"
               Width="80"
               Watermark="Port"
               Text="4000"/>

      <Button Content="Connect"
              Click="OnConnect"/>
    </StackPanel>

    <!-- Center: Output -->
    <ScrollViewer Name="OutputScrollViewer"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Auto">

      <StackPanel Name="OutputPanel"
                  Margin="6"
                  Spacing="2"/>

    </ScrollViewer>

    <!-- Bottom: Input -->
    <StackPanel Orientation="Horizontal"
                DockPanel.Dock="Bottom"
                Margin="5"
                Spacing="5">

      <TextBox Name="InputBox"
               Width="700"/>

      <Button Content="Send"
              Click="OnSend"/>
    </StackPanel>

  </DockPanel>
</Window>