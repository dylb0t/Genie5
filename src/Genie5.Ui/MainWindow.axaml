<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Genie5.Ui.MainWindow"
        Width="900"
        Height="700"
        Title="Genie5">

  <DockPanel>

    <!-- Top: Connection controls -->
    <StackPanel Orientation="Horizontal"
                DockPanel.Dock="Top"
                Margin="5"
                Spacing="5">

      <TextBox Name="HostBox"
               Width="200"
               Watermark="Host"
               Text="aardmud.org"/>

      <TextBox Name="PortBox"
               Width="80"
               Watermark="Port"
               Text="4000"/>

      <Button Content="Connect"
              Click="OnConnect"/>
    </StackPanel>

    <!-- Bottom: Input (must be declared before the fill element) -->
    <Grid DockPanel.Dock="Bottom"
          Margin="5"
          ColumnDefinitions="*,Auto">

      <TextBox Name="InputBox"
               Grid.Column="0"
               Margin="0,0,5,0"/>

      <Button Content="Send"
              Grid.Column="1"
              Click="OnSend"/>
    </Grid>

    <!-- Center: DockControl fills remaining space -->
    <DockControl Name="MainDockControl" />

  </DockPanel>
</Window>