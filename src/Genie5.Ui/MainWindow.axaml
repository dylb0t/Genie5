<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Genie5.Ui.MainWindow"
        Width="800" Height="600"
        Title="Genie5">

  <DockPanel>

    <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="5">
      <TextBox Name="HostBox" Width="200" Watermark="Host"/>
      <TextBox Name="PortBox" Width="80" Margin="5,0" Watermark="Port"/>
      <Button Content="Connect" Click="OnConnect"/>
    </StackPanel>

    <TextBox Name="OutputBox" AcceptsReturn="True" IsReadOnly="True" VerticalScrollBarVisibility="Auto"/>

    <StackPanel Orientation="Horizontal" DockPanel.Dock="Bottom" Margin="5">
      <TextBox Name="InputBox" Width="600"/>
      <Button Content="Send" Click="OnSend" Margin="5,0"/>
    </StackPanel>

  </DockPanel>
</Window>
