<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Genie5.Ui.DialogMapperScriptSettings"
        Title="AutoMapper Script Settings"
        Width="400"
        Height="200"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

  <StackPanel Margin="16" Spacing="12">

    <CheckBox Name="UseScriptCheckBox"
              Content="Use script for #goto walks (instead of built-in engine)"
              IsChecked="False" />

    <StackPanel Orientation="Horizontal" Spacing="8">
      <TextBlock Text="Script name:"
                 VerticalAlignment="Center" />
      <TextBox Name="ScriptNameBox"
               Width="200"
               Text="automapper" />
    </StackPanel>

    <TextBlock Text="When enabled, #goto will launch the script with calculated moves as arguments.&#x0a;Example: .automapper north north east south"
               FontSize="11"
               Foreground="Gray"
               TextWrapping="Wrap" />

    <StackPanel Orientation="Horizontal"
                HorizontalAlignment="Right"
                Spacing="8"
                Margin="0,8,0,0">
      <Button Content="OK"     Width="80" Click="OnOk" />
      <Button Content="Cancel" Width="80" Click="OnCancel" />
    </StackPanel>

  </StackPanel>
</Window>
