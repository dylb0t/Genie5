<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Genie5.Ui.AliasesPanel">

  <Grid RowDefinitions="Auto,*">

    <!-- Toolbar -->
    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="4" Margin="4,4,4,0">
      <Button Content="Add New"  Click="OnAdd" />
      <Button Content="Delete"   Click="OnDelete" />
      <Button Content="Toggle"   Click="OnToggle" />
      <Button Content="Import…"  Click="OnImport" />
    </StackPanel>

    <!-- List + edit form -->
    <Grid Grid.Row="1" ColumnDefinitions="*,*" Margin="4">
      <ListBox Name="ItemsList"
               Grid.Column="0"
               Margin="0,0,4,0"
               SelectionChanged="OnSelectionChanged" />

      <Grid Grid.Column="1"
            RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
            Margin="4,0,0,0">
        <TextBlock Grid.Row="0" Text="Name:" Margin="0,0,0,2" />
        <TextBox   Grid.Row="1" Name="NameBox" Margin="0,0,0,8" />
        <TextBlock Grid.Row="2" Text="Expansion:" Margin="0,0,0,2" />
        <TextBox   Grid.Row="3" Name="ExpansionBox" Margin="0,0,0,8" />
        <CheckBox  Grid.Row="4" Name="EnabledCheck" Content="Enabled" Margin="0,0,0,8" IsChecked="True" />
        <StackPanel Grid.Row="5" Orientation="Horizontal" Spacing="4">
          <Button Content="Save"  Click="OnSave" />
          <Button Content="Clear" Click="OnClear" />
        </StackPanel>
        <TextBlock Grid.Row="6" Name="StatusText" Margin="0,6,0,0" Foreground="Gray" FontStyle="Italic" />
      </Grid>
    </Grid>

  </Grid>
</UserControl>
