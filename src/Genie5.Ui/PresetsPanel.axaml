<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Genie5.Ui.PresetsPanel">

  <Grid ColumnDefinitions="320,*" Margin="6">

    <!-- Left: list of presets -->
    <DataGrid Name="PresetList"
              Grid.Column="0"
              Margin="0,0,6,0"
              IsReadOnly="True"
              SelectionMode="Single"
              CanUserSortColumns="True"
              GridLinesVisibility="Horizontal"
              HeadersVisibility="Column"
              x:CompileBindings="False"
              SelectionChanged="OnSelectionChanged">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Id"   Binding="{Binding Id}"              Width="*" />
        <DataGridTextColumn Header="Fg"   Binding="{Binding ForegroundColor}" Width="Auto" />
        <DataGridTextColumn Header="Bg"   Binding="{Binding BackgroundColor}" Width="Auto" />
        <DataGridTextColumn Header="Line" Binding="{Binding LineGlyph}"       Width="40" />
      </DataGrid.Columns>
    </DataGrid>

    <!-- Right: editor -->
    <StackPanel Grid.Column="1" Spacing="8">

      <TextBlock Text="Preset ID" FontWeight="Bold" />
      <TextBlock Name="IdLabel" Foreground="Gray" />

      <TextBlock Text="Foreground Color" FontWeight="Bold" />
      <StackPanel Orientation="Horizontal" Spacing="8">
        <ColorPicker Name="FgColorPicker" IsAlphaEnabled="False" />
        <CheckBox Name="FgDefaultCheck" Content="Use default" VerticalAlignment="Center"/>
      </StackPanel>

      <TextBlock Text="Background Color" FontWeight="Bold" />
      <StackPanel Orientation="Horizontal" Spacing="8">
        <ColorPicker Name="BgColorPicker" IsAlphaEnabled="False" />
        <CheckBox Name="BgNoneCheck" Content="None" VerticalAlignment="Center"/>
      </StackPanel>

      <CheckBox Name="HighlightLineCheck" Content="Highlight entire line" />

      <Border Name="PreviewBorder" Height="28" Width="180"
              HorizontalAlignment="Left"
              CornerRadius="3" Padding="6,4">
        <TextBlock Name="PreviewText" Text="Preview text" />
      </Border>

      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button Content="Apply"   Click="OnApply" />
        <Button Content="Reset"   Click="OnReset" />
      </StackPanel>

      <TextBlock Name="StatusText" Foreground="Gray" FontStyle="Italic" />

    </StackPanel>
  </Grid>

</UserControl>
