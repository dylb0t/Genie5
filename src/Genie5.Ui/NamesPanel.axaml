<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Genie5.Ui.NamesPanel">

  <Grid RowDefinitions="Auto,*">

    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="4" Margin="4,4,4,0">
      <Button Content="Refresh"  Click="OnRefresh" />
      <Button Content="Add"      Click="OnAdd" />
      <Button Content="Remove"   Click="OnRemove" />
      <Button Content="Load"     Click="OnLoad" />
      <Button Content="Save"     Click="OnSave" />
      <Button Content="Import…"  Click="OnImport" />
    </StackPanel>

    <Grid Grid.Row="1" ColumnDefinitions="*,*" Margin="4">
      <DataGrid Name="ItemsList"
                Grid.Column="0"
                Margin="0,0,4,0"
                IsReadOnly="True"
                SelectionMode="Single"
                CanUserSortColumns="True"
                GridLinesVisibility="Horizontal"
                HeadersVisibility="Column"
                x:CompileBindings="False"
                SelectionChanged="OnSelectionChanged">
        <DataGrid.Columns>
          <DataGridTextColumn Header="Name" Binding="{Binding Name}"            Width="*" />
          <DataGridTextColumn Header="Fg"   Binding="{Binding ForegroundColor}" Width="Auto" />
          <DataGridTextColumn Header="Bg"   Binding="{Binding BackgroundColor}" Width="Auto" />
        </DataGrid.Columns>
      </DataGrid>

      <Grid Grid.Column="1"
            RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
            Margin="4,0,0,0">
        <TextBlock Grid.Row="0" Text="Name:" Margin="0,0,0,2" />
        <TextBox   Grid.Row="1" Name="NameBox" Margin="0,0,0,8" />

        <TextBlock Grid.Row="2" Text="Foreground color:" Margin="0,0,0,2" />
        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
          <ColorPicker Name="FgColorPicker" IsAlphaEnabled="False" />
          <CheckBox Name="FgDefaultCheck" Content="Use default" VerticalAlignment="Center"/>
        </StackPanel>

        <TextBlock Grid.Row="4" Text="Background color:" Margin="0,0,0,2" />
        <StackPanel Grid.Row="5" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
          <ColorPicker Name="BgColorPicker" IsAlphaEnabled="False" />
          <CheckBox Name="BgNoneCheck" Content="None" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="6" Orientation="Horizontal" Spacing="4">
          <Button Content="Save"  Click="OnSaveRule" />
          <Button Content="Clear" Click="OnClear" />
        </StackPanel>

        <TextBlock Grid.Row="7" Name="StatusText" Margin="0,6,0,0"
                   Foreground="Gray" FontStyle="Italic" />
      </Grid>
    </Grid>

  </Grid>
</UserControl>
