<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Genie5.Ui.DialogProfileConnect"
        Title="Connect Using Profile"
        Width="400" Height="360"
        WindowStartupLocation="CenterOwner">

  <Grid RowDefinitions="*,Auto" Margin="12">

    <Grid Grid.Row="0" ColumnDefinitions="*,Auto">

      <ListBox Name="ProfileList"
               Grid.Column="0"
               Margin="0,0,8,0"
               DoubleTapped="OnProfileDoubleTapped" />

      <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Top">
        <Button Content="New..."    Width="80" Click="OnNew" />
        <Button Content="Edit..."   Width="80" Click="OnEdit" />
        <Button Content="Delete"    Width="80" Click="OnDelete" />
      </StackPanel>

    </Grid>

    <StackPanel Grid.Row="1" Orientation="Horizontal"
                HorizontalAlignment="Right" Spacing="8" Margin="0,12,0,0">
      <Button Name="ConnectButton" Content="Connect" Click="OnConnect" />
      <Button Content="Cancel"                       Click="OnCancel" />
    </StackPanel>

  </Grid>
</Window>
