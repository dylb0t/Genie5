<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Genie5.Ui"
             x:Class="Genie5.Ui.App">

  <Application.DataTemplates>
    <DataTemplate DataType="local:GameOutputViewModel">
      <local:GameOutputView />
    </DataTemplate>
    <DataTemplate DataType="local:RoomViewModel">
      <local:RoomView />
    </DataTemplate>
  </Application.DataTemplates>

  <Application.Styles>
    <FluentTheme />
    <DockFluentTheme DensityStyle="Compact" />
  </Application.Styles>
</Application>