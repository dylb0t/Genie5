<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Genie5.Ui.StatusBarView"
             FontFamily="Segoe UI,San Francisco,Arial,sans-serif"
             FontSize="11">

  <Border Background="#1C1C1C"
          BorderBrush="#3A3A3A"
          BorderThickness="0,1,0,0"
          Padding="6,4,6,4">

    <StackPanel Orientation="Vertical" Spacing="3">

      <!-- Row 1: Vitals bars -->
      <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">

        <!-- Health -->
        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
          <TextBlock Text="HP" Foreground="#888888" VerticalAlignment="Center"/>
          <Grid Width="110" Height="15">
            <ProgressBar Name="HealthBar" Minimum="0" Maximum="100" Value="100"
                         Foreground="#4CAF50" Background="#2A2A2A" Height="15"/>
            <TextBlock Name="HealthText" Text="--" FontSize="10"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="White"/>
          </Grid>
        </StackPanel>

        <!-- Mana -->
        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
          <TextBlock Text="Mana" Foreground="#888888" VerticalAlignment="Center"/>
          <Grid Width="110" Height="15">
            <ProgressBar Name="ManaBar" Minimum="0" Maximum="100" Value="100"
                         Foreground="#5B9BD5" Background="#2A2A2A" Height="15"/>
            <TextBlock Name="ManaText" Text="--" FontSize="10"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="White"/>
          </Grid>
        </StackPanel>

        <!-- Stamina -->
        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
          <TextBlock Text="Stam" Foreground="#888888" VerticalAlignment="Center"/>
          <Grid Width="110" Height="15">
            <ProgressBar Name="StaminaBar" Minimum="0" Maximum="100" Value="100"
                         Foreground="#E6A020" Background="#2A2A2A" Height="15"/>
            <TextBlock Name="StaminaText" Text="--" FontSize="10"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="White"/>
          </Grid>
        </StackPanel>

        <!-- Spirit -->
        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
          <TextBlock Text="Sprt" Foreground="#888888" VerticalAlignment="Center"/>
          <Grid Width="110" Height="15">
            <ProgressBar Name="SpiritBar" Minimum="0" Maximum="100" Value="100"
                         Foreground="#C882D8" Background="#2A2A2A" Height="15"/>
            <TextBlock Name="SpiritText" Text="--" FontSize="10"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="White"/>
          </Grid>
        </StackPanel>

        <!-- Concentration -->
        <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
          <TextBlock Text="Conc" Foreground="#888888" VerticalAlignment="Center"/>
          <Grid Width="110" Height="15">
            <ProgressBar Name="ConcBar" Minimum="0" Maximum="100" Value="100"
                         Foreground="#4FC3C3" Background="#2A2A2A" Height="15"/>
            <TextBlock Name="ConcText" Text="--" FontSize="10"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="White"/>
          </Grid>
        </StackPanel>

      </StackPanel>

      <!-- Row 2: Roundtime + Casttime + Indicators + Spell -->
      <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">

        <!-- Roundtime -->
        <StackPanel Name="RoundtimePanel" Orientation="Horizontal" Spacing="4"
                    VerticalAlignment="Center" IsVisible="False">
          <TextBlock Text="RT" Foreground="#FF6B6B" VerticalAlignment="Center"/>
          <Grid Width="80" Height="13">
            <ProgressBar Name="RoundtimeBar" Minimum="0" Maximum="10" Value="0"
                         Foreground="#E53935" Background="#2A2A2A" Height="13"/>
            <TextBlock Name="RoundtimeText" Text="" FontSize="10"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="White"/>
          </Grid>
        </StackPanel>

        <!-- Cast time -->
        <StackPanel Name="CastTimePanel" Orientation="Horizontal" Spacing="4"
                    VerticalAlignment="Center" IsVisible="False">
          <TextBlock Text="CT" Foreground="#7986CB" VerticalAlignment="Center"/>
          <Grid Width="60" Height="13">
            <ProgressBar Name="CastTimeBar" Minimum="0" Maximum="10" Value="0"
                         Foreground="#5C6BC0" Background="#2A2A2A" Height="13"/>
            <TextBlock Name="CastTimeText" Text="" FontSize="10"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="White"/>
          </Grid>
        </StackPanel>

        <!-- Separator -->
        <Border Name="TimeSeparator" Width="1" Height="14"
                Background="#444" IsVisible="False"/>

        <!-- Position indicator (only one shown at a time) -->
        <TextBlock Name="IndicatorStanding"  Text="Standing"  Foreground="#AAAAAA" VerticalAlignment="Center"/>
        <TextBlock Name="IndicatorSitting"   Text="Sitting"   Foreground="#AAAAAA" VerticalAlignment="Center" IsVisible="False"/>
        <TextBlock Name="IndicatorKneeling"  Text="Kneeling"  Foreground="#FFCC00" VerticalAlignment="Center" IsVisible="False"/>
        <TextBlock Name="IndicatorProne"     Text="Prone"     Foreground="#FF9900" VerticalAlignment="Center" IsVisible="False"/>

        <!-- Ailment indicators (shown only when active) -->
        <TextBlock Name="IndicatorStunned"   Text="STUNNED"   Foreground="#FF4444" FontWeight="Bold" VerticalAlignment="Center" IsVisible="False"/>
        <TextBlock Name="IndicatorDead"      Text="DEAD"      Foreground="#FF0000" FontWeight="Bold" VerticalAlignment="Center" IsVisible="False"/>
        <TextBlock Name="IndicatorBleeding"  Text="Bleeding"  Foreground="#FF6666" VerticalAlignment="Center" IsVisible="False"/>
        <TextBlock Name="IndicatorPoisoned"  Text="Poisoned"  Foreground="#88CC44" VerticalAlignment="Center" IsVisible="False"/>
        <TextBlock Name="IndicatorDiseased"  Text="Diseased"  Foreground="#AADD44" VerticalAlignment="Center" IsVisible="False"/>
        <TextBlock Name="IndicatorWebbed"    Text="Webbed"    Foreground="#88AAFF" VerticalAlignment="Center" IsVisible="False"/>
        <TextBlock Name="IndicatorHidden"    Text="Hidden"    Foreground="#888888" VerticalAlignment="Center" IsVisible="False"/>
        <TextBlock Name="IndicatorInvisible" Text="Invisible" Foreground="#666666" VerticalAlignment="Center" IsVisible="False"/>
        <TextBlock Name="IndicatorJoined"    Text="Joined"    Foreground="#AAAAFF" VerticalAlignment="Center" IsVisible="False"/>

        <!-- Spell -->
        <StackPanel Name="SpellPanel" Orientation="Horizontal" Spacing="4"
                    VerticalAlignment="Center" IsVisible="False">
          <Border Width="1" Height="14" Background="#444"/>
          <TextBlock Text="Spell:" Foreground="#888888" VerticalAlignment="Center"/>
          <TextBlock Name="SpellText" Foreground="#C882D8" VerticalAlignment="Center"/>
        </StackPanel>

      </StackPanel>

    </StackPanel>
  </Border>
</UserControl>
