<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Genie5.Ui"
             x:Class="Genie5.Ui.StatusBarView"
             FontFamily="Segoe UI,San Francisco,Arial,sans-serif"
             FontSize="11">

  <Border Background="#111111"
          BorderBrush="#3A3A3A"
          BorderThickness="0,1,0,0">

    <StackPanel Orientation="Vertical">

      <!-- Top row: RT | Compass | Body | L hand | R hand | Spell | Indicators -->
      <Grid ColumnDefinitions="110,40,36,Auto,*,*,Auto,*"
            Height="44"
            Margin="4,2,4,2">

        <!-- RT counter: vertically-stacked R/T label + always-visible box -->
        <Grid Grid.Column="0" ColumnDefinitions="Auto,*"
              VerticalAlignment="Center" Margin="2,0,6,0">
          <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="-2"
                      VerticalAlignment="Center" Margin="2,0,6,0">
            <TextBlock Text="R" Foreground="#888888" FontSize="11" FontWeight="Bold"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="T" Foreground="#888888" FontSize="11" FontWeight="Bold"
                       HorizontalAlignment="Center"/>
          </StackPanel>
          <Border Name="RoundtimeBox" Grid.Column="1"
                  Background="#0A0A0A"
                  BorderBrush="#555"
                  BorderThickness="1"
                  Height="32"
                  VerticalAlignment="Center"
                  ClipToBounds="True">
            <Panel>
              <Rectangle Name="RoundtimeFill"
                         Fill="#1E66E5"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Stretch"
                         Width="0"/>
              <TextBlock Name="RoundtimeText" Text="" FontSize="14" FontWeight="Bold"
                         HorizontalAlignment="Center" VerticalAlignment="Center"
                         Foreground="White"/>
            </Panel>
          </Border>
        </Grid>

        <!-- Compass -->
        <local:CompassView Name="Compass"
                           Grid.Column="1"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>

        <!-- Body silhouette -->
        <local:BodyView Name="BodyDiagram"
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"/>

        <!-- Status effect icons (stunned, bleeding, invisible, hidden, joined, webbed) -->
        <local:StatusIconBar Name="StatusIcons"
                             Grid.Column="3"
                             VerticalAlignment="Center"
                             HorizontalAlignment="Left"
                             Margin="8,0,8,0"/>

        <!-- Left hand -->
        <Border Grid.Column="4"
                Margin="4,4"
                Background="#1A1A1A"
                BorderBrush="#333"
                BorderThickness="1"
                CornerRadius="3"
                Padding="6,3">
          <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
            <TextBlock Text="L" Foreground="#888888" FontWeight="Bold"
                       VerticalAlignment="Center"/>
            <TextBlock Name="LeftHandText" Text="Empty" Foreground="#CCCCCC"
                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
          </StackPanel>
        </Border>

        <!-- Right hand -->
        <Border Grid.Column="5"
                Margin="4,4"
                Background="#1A1A1A"
                BorderBrush="#333"
                BorderThickness="1"
                CornerRadius="3"
                Padding="6,3">
          <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
            <TextBlock Text="R" Foreground="#888888" FontWeight="Bold"
                       VerticalAlignment="Center"/>
            <TextBlock Name="RightHandText" Text="Empty" Foreground="#CCCCCC"
                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
          </StackPanel>
        </Border>

        <!-- Spell + cast time -->
        <Border Grid.Column="6"
                Margin="4,4"
                Background="#1A1A1A"
                BorderBrush="#333"
                BorderThickness="1"
                CornerRadius="3"
                Padding="6,3"
                MinWidth="140">
          <StackPanel Orientation="Vertical" Spacing="2" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" Spacing="5">
              <TextBlock Text="S" Foreground="#888888" FontWeight="Bold"
                         VerticalAlignment="Center"/>
              <TextBlock Name="SpellText" Text="None" Foreground="#C882D8"
                         VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
            </StackPanel>
            <Grid Height="14">
              <ProgressBar Name="CastTimeBar" Minimum="0" Maximum="10" Value="0"
                           Foreground="#5C6BC0" Background="#2A2A2A" Height="14"
                           IsVisible="False"/>
              <TextBlock Name="CastTimeText" Text="" FontSize="10"
                         HorizontalAlignment="Center" VerticalAlignment="Center"
                         Foreground="White"/>
            </Grid>
          </StackPanel>
        </Border>

        <!-- Status indicators (text; icons handle stunned/bleeding/invisible/hidden/joined/webbed) -->
        <WrapPanel Grid.Column="7"
                   Orientation="Horizontal"
                   VerticalAlignment="Center"
                   Margin="6,0">

          <TextBlock Name="IndicatorPoisoned"  Text="Poisoned"  Foreground="#88CC44" Margin="0,0,6,0" IsVisible="False"/>
          <TextBlock Name="IndicatorDiseased"  Text="Diseased"  Foreground="#AADD44" Margin="0,0,6,0" IsVisible="False"/>

        </WrapPanel>

      </Grid>

      <!-- Bottom row: full-width vitals bars -->
      <Grid ColumnDefinitions="*,*,*,*,*" Height="22">

        <Grid Grid.Column="0">
          <ProgressBar Name="HealthBar" Minimum="0" Maximum="100" Value="100"
                       Foreground="#962020" Background="#2A1010"/>
          <TextBlock Name="HealthText" Text="Health --"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     Foreground="White" FontSize="11"/>
        </Grid>

        <Grid Grid.Column="1">
          <ProgressBar Name="ManaBar" Minimum="0" Maximum="100" Value="100"
                       Foreground="#1A5EA8" Background="#101828"/>
          <TextBlock Name="ManaText" Text="Mana --"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     Foreground="White" FontSize="11"/>
        </Grid>

        <Grid Grid.Column="2">
          <ProgressBar Name="ConcBar" Minimum="0" Maximum="100" Value="100"
                       Foreground="#0E7A6A" Background="#101A18"/>
          <TextBlock Name="ConcText" Text="Concentration --"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     Foreground="White" FontSize="11"/>
        </Grid>

        <Grid Grid.Column="3">
          <ProgressBar Name="StaminaBar" Minimum="0" Maximum="100" Value="100"
                       Foreground="#2E7D32" Background="#101810"/>
          <TextBlock Name="StaminaText" Text="Fatigue --"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     Foreground="White" FontSize="11"/>
        </Grid>

        <Grid Grid.Column="4">
          <ProgressBar Name="SpiritBar" Minimum="0" Maximum="100" Value="100"
                       Foreground="#6A1EA0" Background="#180E1A"/>
          <TextBlock Name="SpiritText" Text="Spirit --"
                     HorizontalAlignment="Center" VerticalAlignment="Center"
                     Foreground="White" FontSize="11"/>
        </Grid>

      </Grid>

    </StackPanel>
  </Border>
</UserControl>
