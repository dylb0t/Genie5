<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Genie5.Ui"
             x:Class="Genie5.Ui.HighlightsPanel">

  <TabControl>

    <TabItem Header="Strings">
      <local:HighlightStringsPanel Name="StringsPanelCtrl" />
    </TabItem>

    <TabItem Header="Names">
      <local:NamesPanel Name="NamesPanelCtrl" />
    </TabItem>

    <TabItem Header="Presets">
      <local:PresetsPanel Name="PresetsPanelCtrl" />
    </TabItem>

  </TabControl>
</UserControl>
