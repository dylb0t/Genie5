<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Genie5.Ui.ClassesPanel">

  <Grid RowDefinitions="Auto,*">

    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="4" Margin="4,4,4,0">
      <Button Content="Refresh"     Click="OnRefresh" />
      <Button Content="Activate All"   Click="OnActivateAll" />
      <Button Content="Deactivate All" Click="OnDeactivateAll" />
      <Button Content="Remove"      Click="OnRemove" />
      <Button Content="Import…"     Click="OnImport" />
    </StackPanel>

    <Grid Grid.Row="1" ColumnDefinitions="*,Auto" Margin="4">
      <ListBox Name="ItemsList"
               Grid.Column="0"
               Margin="0,0,4,0"
               SelectionChanged="OnSelectionChanged" />

      <StackPanel Grid.Column="1" Orientation="Vertical" Spacing="4" Width="220">
        <TextBlock Text="Class name:" />
        <TextBox   Name="NameBox" />
        <CheckBox  Name="ActiveCheck" Content="Active" IsChecked="True" />
        <StackPanel Orientation="Horizontal" Spacing="4">
          <Button Content="Save"  Click="OnSave" />
          <Button Content="Clear" Click="OnClear" />
        </StackPanel>
        <TextBlock Name="StatusText" Margin="0,6,0,0" Foreground="Gray" FontStyle="Italic" TextWrapping="Wrap" />
      </StackPanel>
    </Grid>

  </Grid>
</UserControl>
