<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Genie5.Ui.DialogConnect"
        Title="Connect"
        Width="320" Height="160"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

  <Grid RowDefinitions="Auto,Auto,Auto" Margin="16">

    <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto,80" Margin="0,0,0,12">
      <TextBlock Grid.Column="0" Text="Host:" VerticalAlignment="Center" Margin="0,0,8,0"/>
      <TextBox   Grid.Column="1" Name="HostBox" Text="aardmud.org" />
      <TextBlock Grid.Column="2" Text="Port:" VerticalAlignment="Center" Margin="12,0,8,0"/>
      <TextBox   Grid.Column="3" Name="PortBox" Text="4000" />
    </Grid>

    <TextBlock Grid.Row="1" Name="StatusText" Foreground="Gray" FontStyle="Italic"
               Margin="0,0,0,12" Text=" " />

    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
      <Button Name="ConnectButton" Content="Connect" Click="OnConnect" />
      <Button Content="Cancel" Click="OnCancel" />
    </StackPanel>

  </Grid>
</Window>
