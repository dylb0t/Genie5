<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Genie5.Ui.DialogProfileEdit"
        Title="Edit Profile"
        Width="380" Height="400"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

  <Grid RowDefinitions="*,Auto" Margin="16">

    <Grid Grid.Row="0"
          RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">

      <TextBlock Grid.Row="0" Text="Profile name:" Margin="0,0,0,2"/>
      <TextBox   Grid.Row="1" Name="NameBox" Margin="0,0,0,10"/>

      <!-- Connection type toggle -->
      <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="16" Margin="0,0,0,10">
        <RadioButton Name="SimuRadio"   Content="Simutronics game"  GroupName="ConnType"
                     IsChecked="True"  IsCheckedChanged="OnTypeChanged"/>
        <RadioButton Name="DirectRadio" Content="Direct TCP"        GroupName="ConnType"
                     IsCheckedChanged="OnTypeChanged"/>
      </StackPanel>

      <!-- Simutronics fields -->
      <Grid Grid.Row="3" Name="SimuFields" ColumnDefinitions="90,*" Margin="0,0,0,8">
        <TextBlock Grid.Column="0" Text="Game:" VerticalAlignment="Center"/>
        <ComboBox  Grid.Column="1" Name="GameBox" HorizontalAlignment="Stretch"/>
      </Grid>

      <Grid Grid.Row="4" Name="CharRow" ColumnDefinitions="90,*" Margin="0,0,0,8">
        <TextBlock Grid.Column="0" Text="Character:" VerticalAlignment="Center"/>
        <TextBox   Grid.Column="1" Name="CharacterBox" Watermark="Leave blank for list on connect"/>
      </Grid>

      <!-- Direct TCP fields -->
      <Grid Grid.Row="5" Name="DirectFields" ColumnDefinitions="90,*,16,80"
            Margin="0,0,0,8" IsVisible="False">
        <TextBlock Grid.Column="0" Text="Host:" VerticalAlignment="Center"/>
        <TextBox   Grid.Column="1" Name="HostBox"/>
        <TextBox   Grid.Column="3" Name="PortBox" Watermark="Port"/>
      </Grid>

      <TextBlock Grid.Row="6" Text="Account:" Margin="0,0,0,2"/>
      <TextBox   Grid.Row="7" Name="AccountBox" Margin="0,0,0,8"/>

      <TextBlock Grid.Row="8" Text="Password (blank = keep existing):" Margin="0,0,0,2"/>
      <TextBox   Grid.Row="9" Name="PasswordBox" PasswordChar="●" Margin="0,0,0,4"/>

      <CheckBox  Grid.Row="10" Name="AutoConnectBox" Content="Connect automatically on startup"
                 Margin="0,4,0,4"/>
      <TextBlock Grid.Row="11" Name="StatusText" Foreground="Gray" FontStyle="Italic" Text=" "/>
    </Grid>

    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
      <Button Content="Save"   Click="OnSave"/>
      <Button Content="Cancel" Click="OnCancel"/>
    </StackPanel>

  </Grid>
</Window>
